{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",

  "enabled": true,
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "chat",

  "manualMode": {
    "enabled": true,
    "automaticStrategies": true
  },

  "commands": {
    "enabled": true,
    "protectedTools": ["skill", "todowrite"]
  },

  "protectedFilePatterns": [
    "AGENTS.md",
    "PROJECT_MAP.md",
    "TASKS.md",
    ".opencode/skills/**",
    "app/fretio/src/fretio/providers/rodonaves.py",
    "app/fretio/src/fretio/providers/translovato.py"
  ],

  "compress": {
    "permission": "ask",
    "showCompression": false,
    "minContextLimit": 50000,
    "maxContextLimit": 100000,
    "nudgeFrequency": 5,
    "iterationNudgeThreshold": 12,
    "nudgeForce": "soft",
    "protectUserMessages": false,
    "protectedTools": ["skill", "todowrite"]
  },

  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": ["skill"]
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": ["skill"]
    }
  }
}
