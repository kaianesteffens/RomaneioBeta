{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/gpt-5.4-mini",
  "small_model": "openai/gpt-5.4-mini",

  "share": "disabled",
  "default_agent": "caveman-plan",

  "instructions": [
    "AGENTS.md",
    "PROJECT_MAP.md",
    "TASKS.md"
  ],

  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },

  "permission": {
    "*": "ask",

    "read": "allow",
    "grep": "allow",
    "glob": "allow",

    "edit": "ask",
    "write": "ask",
    "apply_patch": "ask",

    "webfetch": "ask",
    "websearch": "ask",

    "bash": {
      "*": "ask",

      "pwd": "allow",
      "ls *": "allow",
      "find *": "allow",
      "grep *": "allow",

      "git status*": "allow",
      "git diff*": "allow",
      "git branch*": "allow",
      "git log*": "allow",

      "pytest*": "ask",
      "python -m pytest*": "ask",
      "python *": "ask",

      "git add*": "ask",
      "git commit*": "deny",
      "git push*": "deny",
      "git clean*": "deny",
      "git reset --hard*": "deny",

      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "deny",

      "pip install*": "ask",
      "npm install*": "ask"
    },

    "skill": {
      "*": "ask",
      "no-comment-noise": "allow",
      "provider-captcha": "allow",
      "desktop-scope": "allow",
      "token-economy": "allow",
      "test-evidence": "allow",
      "pr-merge-gate": "allow"
    }
  },

  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "__pycache__/**",
      ".pytest_cache/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "logs/**",
      "Fretio_data/**",
      "*.pyc"
    ]
  }
}
